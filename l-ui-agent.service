[Unit]
Description=L-UI Agent Service
After=network.target

[Service]
Type=simple
ExecStart=/usr/local/l-ui-agent/l-ui-agent
EnvironmentFile=-/etc/default/l-ui
Restart=on-failure
RestartSec=5s

# Hardening
ProtectSystem=full
ProtectHome=true
PrivateTmp=true
NoNewPrivileges=true
RestrictSUIDSGID=true
ReadWritePaths=/etc/l-ui /var/log/l-ui /etc/ufw
RuntimeDirectory=l-ui
StateDirectory=l-ui
LogsDirectory=l-ui

[Install]
WantedBy=multi-user.target
